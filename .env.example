# ==========================================
# GRACIE BARRA GUARNE - CONFIGURACIÓN DE ENTORNO
# ==========================================

# 1. Configuración Principal de Django
DJANGO_SECRET_KEY="django-insecure-graciebarra-guarne-secret-key-prod-2026-change-me"
DEBUG=True
ALLOWED_HOSTS="localhost,127.0.0.1,0.0.0.0,.railway.app"

# 2. Control de Roles Google Auth (RBAC)
# Correo del profesor / administrador. Si el usuario que inicia sesión con Google
# coincide con este correo, se le asigna el rol 'ADMIN'. De lo contrario, 'STUDENT'.
ADMIN_EMAIL="profesor@graciebarra.com"
VITE_ADMIN_EMAIL="profesor@graciebarra.com"

# 3. Google OAuth 2.0 Credentials (Google Sign-In)
GOOGLE_OAUTH_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="your-google-client-secret"
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# 4. Configuración de Base de Datos PostgreSQL / SQLite
# Formato URL para Docker/Railway: postgresql://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL="postgresql://postgres:postgres@db:5432/graciebarra_db"

# Alternativa variables individuales PostgreSQL (para Docker local):
POSTGRES_DB="graciebarra_db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres_secure_password"
POSTGRES_HOST="db"
POSTGRES_PORT=5432

# 5. Servidor de Correo SMTP (Alertas Automáticas de Pago)
EMAIL_BACKEND="django.core.mail.backends.smtp.EmailBackend"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER="pagos@graciebarraguarne.com"
EMAIL_HOST_PASSWORD="your-app-specific-password"
DEFAULT_FROM_EMAIL="Gracie Barra Guarne <pagos@graciebarraguarne.com>"

# 6. Gemini AI & System Variables
GEMINI_API_KEY="your-gemini-api-key"
APP_URL="http://localhost:3000"
